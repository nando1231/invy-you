# ============================================================
# Invy-You — Production Environment Variables
# ============================================================
# Copy this file and fill in real values.
# NEVER commit the filled file — it is listed in .gitignore.
# ============================================================

# ------------------------------------------------------------
# Frontend (Vercel) — set these in the Vercel dashboard
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon key from supabase.com>

# ------------------------------------------------------------
# Supabase Edge Function Secrets
# Set these via: supabase secrets set KEY=value
# Or in the Supabase dashboard → Project Settings → Edge Functions
# ------------------------------------------------------------

# AI Provider — escolhe um: ollama | openai | gemini | anthropic
AI_PROVIDER=ollama

# Ollama (VPS Hetzner — necessário se AI_PROVIDER=ollama)
OLLAMA_URL=http://<VPS_IP>:11434/api/generate
OLLAMA_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=qwen2.5vl:7b

# OpenAI (necessário se AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (necessário se AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude (necessário se AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# VPS Hetzner — WAHA (WhatsApp)
WAHA_URL=http://<VPS_IP>:3000
WAHA_API_KEY=<same key configured in docker-compose on VPS>

# VPS Hetzner — Whisper (speech-to-text)
WHISPER_URL=http://<VPS_IP>:9000

# Shared secret tokens — generate with: openssl rand -hex 32
WEBHOOK_TOKEN=<random hex 64 chars>
CRON_SECRET=<random hex 64 chars>
TRIGGER_SECRET=<random hex 64 chars>

# ------------------------------------------------------------
# GitHub Actions Secrets
# Set these in: GitHub repo → Settings → Secrets → Actions
# ------------------------------------------------------------
# SUPABASE_ACCESS_TOKEN — from supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF  — e.g. knibrepitgiejyqgpofi

# ------------------------------------------------------------
# VPS docker-compose .env (on the Hetzner server)
# ------------------------------------------------------------
# WAHA_API_KEY=<same as above>
